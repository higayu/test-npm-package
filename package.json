{
  "name": "@example/safe-npm-package",
  "version": "1.0.0",
  "description": "A safe example npm package configuration.",
  "type": "module",
  "license": "MIT",
  "author": "Example Author",
  "homepage": "https://github.com/example/safe-npm-package#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/example/safe-npm-package.git"
  },
  "bugs": {
    "url": "https://github.com/example/safe-npm-package/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "example",
    "typescript",
    "npm-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {},
  "peerDependencies": {},
  "optionalDependencies": {},
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}